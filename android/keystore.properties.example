# Release signing credentials. Copy to `keystore.properties` (git-ignored) and fill in.
# storeFile is resolved relative to the android/ project root.
#
# Generate an upload key once:
#   keytool -genkeypair -v -keystore upload-keystore.jks -alias upload \
#     -keyalg RSA -keysize 2048 -validity 10000
# Then enroll in Play App Signing when you create the app in Play Console.

storeFile=upload-keystore.jks
storePassword=CHANGE_ME
keyAlias=upload
keyPassword=CHANGE_ME
