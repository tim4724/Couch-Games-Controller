<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
	<!-- The app does no tracking and runs no cross-app/advertising identifiers. -->
	<key>NSPrivacyTracking</key>
	<false/>
	<key>NSPrivacyTrackingDomains</key>
	<array/>
	<!-- No data leaves the device for the app's own purposes: the QR camera scan is
	     on-device only, and the profile/room history live in local UserDefaults. -->
	<key>NSPrivacyCollectedDataTypes</key>
	<array/>
	<!-- Required-reason APIs actually used by the app. Only UserDefaults (Data/Stores.swift,
	     handle + recent-room persistence). Reason CA92.1: access to info stored only in and
	     accessible only to the app itself. -->
	<key>NSPrivacyAccessedAPITypes</key>
	<array>
		<dict>
			<key>NSPrivacyAccessedAPIType</key>
			<string>NSPrivacyAccessedAPICategoryUserDefaults</string>
			<key>NSPrivacyAccessedAPITypeReasons</key>
			<array>
				<string>CA92.1</string>
			</array>
		</dict>
	</array>
</dict>
</plist>
